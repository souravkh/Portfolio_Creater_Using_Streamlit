{
	"name": "Debian",
	"image": "mcr.microsoft.com/devcontainers/base:bookworm",
	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"installTools": true,
			"version": "3.10"
		}
	},
	"postCreateCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt",
	"forwardPorts": [8000],
	"customizations": {
		"vscode": {
			"extensions":[
			"ms-python.python",
        	"ms-python.vscode-pylance"
			]
		}	
	},
	"remoteUser": "vscode"
}
